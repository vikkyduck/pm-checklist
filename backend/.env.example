# ───── База данных PostgreSQL (Beget / Timeweb) ─────
# В панели хостинга создайте БД и скопируйте значения сюда
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pm_checklist
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ───── SMTP для отправки писем ─────
# Beget: smtp.beget.com  (порт 465, SSL)
# Timeweb: smtp.timeweb.ru  (порт 465, SSL)
SMTP_HOST=smtp.beget.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@yourdomain.ru
SMTP_PASSWORD=your_email_password
SMTP_FROM_NAME=PM Чек-лист Авито

# ───── Безопасность ─────
# Сгенерируйте случайную строку 64+ символа: `openssl rand -hex 64`
JWT_SECRET=change_me_to_a_long_random_string

# ───── URL фронтенда (куда вести из письма) ─────
FRONTEND_URL=https://pm-checklist.lovable.app

# ───── Порт сервера ─────
PORT=3000
